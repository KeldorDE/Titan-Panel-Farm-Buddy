# EditorConfig – https://editorconfig.org
# WoW Addon Development
root = true

# ──────────────────────────────────────────────
# Globale Defaults
# ──────────────────────────────────────────────
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

# ──────────────────────────────────────────────
# Lua – Hauptsprache für WoW Addons
# Lua 5.1 (WoW-Runtime), 4 Spaces ist der Community-Standard
# ──────────────────────────────────────────────
[*.lua]
indent_style = space
indent_size = 4
max_line_length = 120

# ──────────────────────────────────────────────
# TOC – Addon-Manifest (Table of Contents)
# Schlüssel/Wert-Format, kein Einrücken nötig
# ──────────────────────────────────────────────
[*.toc]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

# ──────────────────────────────────────────────
# XML – UI-Layout-Dateien (Frames, Templates)
# ──────────────────────────────────────────────
[*.xml]
indent_style = space
indent_size = 2

# ──────────────────────────────────────────────
# pkgmeta – BigWigs Packager Konfiguration (YAML)
# ──────────────────────────────────────────────
[*.pkgmeta]
indent_style = space
indent_size = 2

# ──────────────────────────────────────────────
# YAML – GitHub Actions / CI
# ──────────────────────────────────────────────
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# ──────────────────────────────────────────────
# Markdown – README, Changelogs
# ──────────────────────────────────────────────
[*.md]
trim_trailing_whitespace = false
max_line_length = off